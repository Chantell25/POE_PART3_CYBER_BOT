<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Local offline feed — populated by setup.ps1 -->
    <add key="local-packages" value=".\packages" />
    <!-- Fallback to nuget.org if the local feed is missing a package -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
