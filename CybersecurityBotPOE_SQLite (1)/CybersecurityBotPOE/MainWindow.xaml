<Window x:Class="CybersecurityBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot - PROG6221 POE (Part 3)"
        Height="740" Width="1040"
        MinHeight="640" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: Header -->
        <Border Grid.Row="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#00FF88" Margin="0,0,8,0"/>
                    <TextBlock Text="CYBERSECURITY AWARENESS BOT  -  PROG6221 POE (Part 3)"
                               Foreground="#00D4FF" FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnHelp" Content="Help" Width="65" Height="30"
                            Background="#161B22" Foreground="#00D4FF"
                            BorderBrush="#00D4FF" BorderThickness="1"
                            FontFamily="Consolas" FontSize="12" Cursor="Hand"
                            Margin="0,0,6,0" Click="BtnHelp_Click"/>
                    <Button x:Name="BtnMemory" Content="Memory" Width="72" Height="30"
                            Background="#161B22" Foreground="#00D4FF"
                            BorderBrush="#00D4FF" BorderThickness="1"
                            FontFamily="Consolas" FontSize="12" Cursor="Hand"
                            Margin="0,0,6,0" Click="BtnMemory_Click"/>
                    <Button x:Name="BtnClear" Content="Clear Chat" Width="90" Height="30"
                            Background="#161B22" Foreground="#00D4FF"
                            BorderBrush="#00D4FF" BorderThickness="1"
                            FontFamily="Consolas" FontSize="12" Cursor="Hand"
                            Click="BtnClear_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 1: ASCII art -->
        <Border Grid.Row="1" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,0,0,1" Padding="6,4">
            <TextBlock x:Name="AsciiBlock"
                       FontFamily="Consolas" FontSize="9" Foreground="#1A5276"
                       HorizontalAlignment="Center" TextAlignment="Center"/>
        </Border>

        <!-- ROW 2: Tab control with Chat / Tasks / Activity Log -->
        <TabControl Grid.Row="2" Background="#0D1117" BorderThickness="0" Margin="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#161B22"/>
                    <Setter Property="Foreground" Value="#8B949E"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="14,8"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#0D1117"/>
                            <Setter Property="Foreground" Value="#00D4FF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ══════════════ TAB 1: CHAT ══════════════ -->
            <TabItem Header="Chat">
                <Grid Background="#0D1117">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="210"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#0D1117">
                        <ScrollViewer x:Name="ChatScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="MessagePanel" Margin="10,8,10,8"/>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="1" Background="#161B22" BorderBrush="#30363D" BorderThickness="1,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="10,10,10,10">

                                <TextBlock Text="QUICK TOPICS" Foreground="#00D4FF"
                                           FontFamily="Consolas" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>

                                <Button Content="Password Safety" Height="28" Margin="0,2,0,2"
                                        Background="#161B22" Foreground="#E6EDF3" BorderBrush="#30363D" BorderThickness="1"
                                        FontFamily="Consolas" FontSize="11" Cursor="Hand"
                                        Tag="password" Click="TopicBtn_Click"/>
                                <Button Content="Phishing" Height="28" Margin="0,2,0,2"
                                        Background="#161B22" Foreground="#E6EDF3" BorderBrush="#30363D" BorderThickness="1"
                                        FontFamily="Consolas" FontSize="11" Cursor="Hand"
                                        Tag="phishing" Click="TopicBtn_Click"/>
                                <Button Content="Privacy" Height="28" Margin="0,2,0,2"
                                        Background="#161B22" Foreground="#E6EDF3" BorderBrush="#30363D" BorderThickness="1"
                                        FontFamily="Consolas" FontSize="11" Cursor="Hand"
                                        Tag="privacy" Click="TopicBtn_Click"/>
                                <Button Content="Malware" Height="28" Margin="0,2,0,2"
                                        Background="#161B22" Foreground="#E6EDF3" BorderBrush="#30363D" BorderThickness="1"
                                        FontFamily="Consolas" FontSize="11" Cursor="Hand"
                                        Tag="malware" Click="TopicBtn_Click"/>
                                <Button Content="Scams" Height="28" Margin="0,2,0,2"
                                        Background="#161B22" Foreground="#E6EDF3" BorderBrush="#30363D" BorderThickness="1"
                                        FontFamily="Consolas" FontSize="11" Cursor="Hand"
                                        Tag="scam" Click="TopicBtn_Click"/>
                                <Button Content="2FA" Height="28" Margin="0,2,0,2"
                                        Background="#161B22" Foreground="#E6EDF3" BorderBrush="#30363D" BorderThickness="1"
                                        FontFamily="Consolas" FontSize="11" Cursor="Hand"
                                        Tag="2fa" Click="TopicBtn_Click"/>
                                <Button Content="Start Quiz" Height="28" Margin="0,2,0,2"
                                        Background="#1A3A2A" Foreground="#00FF88" BorderBrush="#00FF88" BorderThickness="1"
                                        FontFamily="Consolas" FontSize="11" Cursor="Hand"
                                        Tag="quiz" Click="TopicBtn_Click"/>

                                <Separator Background="#30363D" Margin="0,10,0,10"/>

                                <TextBlock Text="BOT MEMORY" Foreground="#FFC107"
                                           FontFamily="Consolas" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="MemNameLabel" Text="Name: -" Foreground="#8B949E"
                                           FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                <TextBlock x:Name="MemTopicLabel" Text="Interest: -" Foreground="#8B949E"
                                           FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                <TextBlock x:Name="MemLastLabel" Text="Last topic: -" Foreground="#8B949E"
                                           FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,2"/>

                                <Separator Background="#30363D" Margin="0,10,0,10"/>

                                <TextBlock Text="MOOD DETECTOR" Foreground="#FF4757"
                                           FontFamily="Consolas" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                <Border x:Name="SentimentBorder" Background="#1C2333"
                                        BorderBrush="#30363D" BorderThickness="1" Padding="8,6">
                                    <TextBlock x:Name="SentimentLabel" Text="Neutral" Foreground="#8B949E"
                                               FontFamily="Consolas" FontSize="12" TextAlignment="Center"/>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════ TAB 2: TASKS ══════════════ -->
            <TabItem Header="Tasks">
                <Grid Background="#0D1117" Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- DB status -->
                    <Border Grid.Row="0" x:Name="DbStatusBorder" Background="#1C2333"
                            BorderBrush="#30363D" BorderThickness="1" Padding="10,6" Margin="0,0,0,10">
                        <TextBlock x:Name="DbStatusLabel" Text="Checking database connection..."
                                   Foreground="#8B949E" FontFamily="Consolas" FontSize="11"/>
                    </Border>

                    <!-- Add task form -->
                    <Border Grid.Row="1" Background="#161B22" BorderBrush="#30363D" BorderThickness="1"
                            Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="ADD NEW TASK" Foreground="#00D4FF"
                                       FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Title:" Foreground="#8B949E"
                                           FontFamily="Consolas" FontSize="12" Width="90"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="TaskTitleBox" Grid.Column="1" Height="32"
                                         Background="#0D1117" Foreground="#E6EDF3"
                                         CaretBrush="#00D4FF" BorderBrush="#30363D" BorderThickness="1"
                                         FontFamily="Consolas" FontSize="12" Padding="6,0,6,0"
                                         VerticalContentAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Description:" Foreground="#8B949E"
                                           FontFamily="Consolas" FontSize="12" Width="90"
                                           VerticalAlignment="Top" Margin="0,6,0,0"/>
                                <TextBox x:Name="TaskDescBox" Grid.Column="1" Height="56"
                                         Background="#0D1117" Foreground="#E6EDF3"
                                         CaretBrush="#00D4FF" BorderBrush="#30363D" BorderThickness="1"
                                         FontFamily="Consolas" FontSize="12" Padding="6,4,6,4"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Reminder:" Foreground="#8B949E"
                                           FontFamily="Consolas" FontSize="12" Width="90"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="ReminderCombo" Grid.Column="1" Height="32"
                                          FontFamily="Consolas" FontSize="12"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="No reminder"/>
                                    <ComboBoxItem Content="Tomorrow"/>
                                    <ComboBoxItem Content="In 3 days"/>
                                    <ComboBoxItem Content="In 7 days"/>
                                    <ComboBoxItem Content="In 14 days"/>
                                    <ComboBoxItem Content="In 30 days"/>
                                </ComboBox>
                            </Grid>

                            <Button x:Name="BtnAddTask" Content="ADD TASK" Height="36" Width="140"
                                    HorizontalAlignment="Left"
                                    Background="#1A3A2A" Foreground="#00FF88"
                                    BorderBrush="#00FF88" BorderThickness="1"
                                    FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                    Cursor="Hand" Click="BtnAddTask_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Task list -->
                    <Border Grid.Row="2" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="YOUR TASKS" Foreground="#00D4FF"
                                       FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="TasksListPanel"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════ TAB 3: ACTIVITY LOG ══════════════ -->
            <TabItem Header="Activity Log">
                <Grid Background="#0D1117" Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="RECENT BOT ACTIONS" Foreground="#00D4FF"
                               FontFamily="Consolas" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Border Grid.Row="1" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="LogListPanel"/>
                        </ScrollViewer>
                    </Border>

                    <Button Grid.Row="2" x:Name="BtnShowMoreLog" Content="Show full history"
                            Height="34" Width="160" HorizontalAlignment="Left" Margin="0,10,0,0"
                            Background="#161B22" Foreground="#00D4FF"
                            BorderBrush="#00D4FF" BorderThickness="1"
                            FontFamily="Consolas" FontSize="12" Cursor="Hand"
                            Click="BtnShowMoreLog_Click"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ROW 3: Input bar (always visible regardless of active tab) -->
        <Border Grid.Row="3" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,1,0,0" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,8,0">
                    <TextBox x:Name="InputBox"
                             Background="#0D1117" Foreground="#E6EDF3"
                             CaretBrush="#00D4FF" BorderBrush="#30363D" BorderThickness="1"
                             FontFamily="Consolas" FontSize="13"
                             Height="38" Padding="8,0,8,0"
                             VerticalContentAlignment="Center"
                             KeyDown="InputBox_KeyDown"
                             GotFocus="InputBox_GotFocus"
                             LostFocus="InputBox_LostFocus"
                             TextChanged="InputBox_TextChanged"/>
                    <TextBlock x:Name="PlaceholderLabel"
                               Text="Try: 'Add a task to enable 2FA' or 'show activity log'..."
                               Foreground="#3D444D" FontFamily="Consolas" FontSize="13"
                               VerticalAlignment="Center" Margin="10,0,0,0"
                               IsHitTestVisible="False"/>
                </Grid>

                <Button x:Name="SendBtn" Grid.Column="1"
                        Content="SEND" Width="80" Height="38"
                        Background="#1A3A2A" Foreground="#00FF88"
                        BorderBrush="#00FF88" BorderThickness="1"
                        FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                        Cursor="Hand" Click="SendBtn_Click"/>
            </Grid>
        </Border>

        <!-- ROW 4: Status bar -->
        <Border Grid.Row="4" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,1,0,0" Padding="10,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel" Grid.Column="0" Text="Ready"
                           Foreground="#8B949E" FontFamily="Consolas" FontSize="11"/>
                <TextBlock x:Name="MsgCountLabel" Grid.Column="1"
                           Foreground="#30363D" FontFamily="Consolas" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Name entry dialog overlay -->
        <Grid x:Name="NameDialog" Grid.Row="0" Grid.RowSpan="5"
              Background="#CC000000" Panel.ZIndex="99" Visibility="Visible">
            <Border Background="#161B22" BorderBrush="#00D4FF" BorderThickness="2"
                    Width="460" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                <StackPanel>
                    <TextBlock Text="CYBERSECURITY AWARENESS BOT" Foreground="#00D4FF"
                               FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                               TextAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Hello! Welcome to the Cybersecurity Awareness Bot."
                               Foreground="#E6EDF3" FontFamily="Consolas" FontSize="12"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <TextBlock Text="I am here to help you stay safe online."
                               Foreground="#E6EDF3" FontFamily="Consolas" FontSize="12"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,20"/>
                    <TextBlock Text="Please enter your name to get started:"
                               Foreground="#8B949E" FontFamily="Consolas" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="NameInputBox"
                             Background="#0D1117" Foreground="#E6EDF3"
                             CaretBrush="#00D4FF" BorderBrush="#00D4FF" BorderThickness="1"
                             FontFamily="Consolas" FontSize="13"
                             Height="38" Padding="8,0,8,0"
                             VerticalContentAlignment="Center"
                             MaxLength="30" Margin="0,0,0,6"
                             KeyDown="NameInputBox_KeyDown"/>
                    <TextBlock x:Name="NameErrorLabel" Foreground="#FF4757"
                               FontFamily="Consolas" FontSize="11" Margin="0,0,0,10"
                               Visibility="Collapsed" TextWrapping="Wrap"/>
                    <Button Content="START CHATTING" Height="40"
                            Background="#1A3A2A" Foreground="#00FF88"
                            BorderBrush="#00FF88" BorderThickness="1"
                            FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                            Cursor="Hand" Click="BtnStartChat_Click"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
